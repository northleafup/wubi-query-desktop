# 运行时复制的大文件（由构建脚本复制，不需要版本控制）
build/bin/assets/
build/fonts/

# 大型资源文件变化提示（但保留源文件）
assets/images/char/*.gif
assets/data/*.tsv

# 但保留目录结构
!assets/images/char/.gitkeep
!assets/data/.gitkeep

# ImGui 配置文件
config/imgui.ini
imgui.ini

